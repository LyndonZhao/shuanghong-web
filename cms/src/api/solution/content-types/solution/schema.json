{
  "kind": "collectionType",
  "collectionName": "solutions",
  "info": {
    "singularName": "solution",
    "pluralName": "solutions",
    "displayName": "解决方案",
    "description": "解决方案/案例卡片"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["multimodal", "ai_application"],
      "required": true,
      "default": "multimodal"
    },
    "description": {
      "type": "richtext"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "tags": {
      "type": "json"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.meta"
    },
    "sections": {
      "type": "component",
      "repeatable": true,
      "component": "case.section"
    }
  }
}
